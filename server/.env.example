PORT=5000
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Option 1: paste the full Supabase Postgres connection string here.
DATABASE_URL=postgresql://postgres:your_database_password@db.your-project-ref.supabase.co:5432/postgres

# Option 2: let the server build the connection string from parts.
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your_database_password
